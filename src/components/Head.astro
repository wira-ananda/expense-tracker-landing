---
// Define props dengan default value untuk SEO
interface Props {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
}

const {
  title = "ExpenseTracker | Kelola Uang Lebih Tenang, Wujudkan Impian",
  description = "Aplikasi pencatatan keuangan pribadi yang simpel, cepat, dan aman. Atur budget harian, pantau pengeluaran, dan capai target finansial Anda hari ini.",
  image = "/og-cover.png",
  noindex = false,
} = Astro.props;

// Mengambil URL absolut. Pastikan 'site' di config sudah benar (misal: https://expensetracker.id)
const canonicalURL = new URL(
  Astro.url.pathname,
  Astro.site || "https://expensetracker-system.vercel.app",
);
const socialImageURL = new URL(
  image,
  Astro.site || "https://expensetracker-system.vercel.app",
);
---

<meta charset="utf-8" />
<meta
  name="viewport"
  content="width=device-width, initial-scale=1, viewport-fit=cover"
/>
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<meta name="generator" content={Astro.generator} />

<link rel="canonical" href={canonicalURL} />
<meta
  name="google-site-verification"
  content="VdanyLXBh8xtrLoBDI1BdqqbDduXuvjlIya7OKOLhGY"
/>

<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<meta name="theme-color" content="#0e8a5d" />
<meta
  name="robots"
  content={noindex
    ? "noindex, nofollow"
    : "index, follow, max-video-preview:-1, max-image-preview:large, max-snippet:-1"}
/>

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap"
  rel="stylesheet"
  media="print"
  onload="this.media='all'"
/>
<noscript>
  <link
    href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap"
    rel="stylesheet"
  />
</noscript>

<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={socialImageURL} />
<meta property="og:locale" content="id_ID" />

<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalURL} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={socialImageURL} />

<link rel="sitemap" href="/sitemap-index.xml" />

<script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "ExpenseTracker",
    "operatingSystem": "Web",
    "applicationCategory": "FinanceApplication",
    "description": "Solusi cerdas kelola keuangan pribadi dengan pencatatan otomatis dan analitik visual.",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "IDR"
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.9",
      "ratingCount": "1250"
    },
    "author": {
      "@type": "Person",
      "name": "Wira Ananda",
      "url": "https://wiraananda.vercel.app/"
    }
  }
</script>
