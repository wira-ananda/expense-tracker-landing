---
import {
  IoCheckmarkCircle,
  IoArrowForward,
  IoLogInOutline,
} from "react-icons/io5";

const ctaBenefits = [
  "Mulai gratis, tanpa kartu kredit",
  "Pantau keuangan rapi setiap hari",
  "Akses sinkron di mobile & web",
];
---

<section
  class="relative overflow-hidden bg-white px-6 pb-10 md:px-12"
  aria-labelledby="cta-title"
>
  <div class="absolute inset-0 z-0 opacity-40 pointer-events-none">
    <div
      class="absolute -top-24 -left-24 h-96 w-96 rounded-full bg-emerald-50 blur-3xl"
    >
    </div>
    <div
      class="absolute -bottom-24 -right-24 h-96 w-96 rounded-full bg-slate-50 blur-3xl"
    >
    </div>
  </div>

  <div class="relative z-10 mx-auto max-w-5xl text-center">
    <span
      class="mb-4 inline-block text-xs font-bold uppercase tracking-widest text-emerald-600 md:text-sm"
    >
      Gabung Bersama 10,000+ Pengguna
    </span>

    <h2
      id="cta-title"
      class="text-balance text-3xl font-black tracking-tight text-slate-900 sm:text-4xl md:text-5xl lg:text-6xl"
    >
      Siap Ambil Kendali atas <span class="text-emerald-600"
        >Keuangan Anda?</span
      >
    </h2>

    <p
      class="mx-auto mt-6 max-w-2xl text-balance text-base leading-relaxed text-slate-600 md:text-lg lg:text-xl"
    >
      Atur pemasukan, pengeluaran, dan target anggaran dengan lebih tenang.
      Sederhanakan hidup Anda mulai hari ini bersama ExpenseTracker.
    </p>

    <ul
      class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row sm:gap-8"
      aria-label="Keunggulan utama"
    >
      {
        ctaBenefits.map((benefit) => (
          <li class="flex items-center gap-2 text-sm font-semibold text-slate-700 md:text-base">
            <IoCheckmarkCircle
              className="h-5 w-5 text-emerald-500 shrink-0"
              aria-hidden="true"
            />
            <span>{benefit}</span>
          </li>
        ))
      }
    </ul>

    <div
      class="mt-12 flex flex-col items-center justify-center gap-4 sm:flex-row"
    >
      <a
        href="/register"
        class="group inline-flex h-14 w-full items-center justify-center gap-2 rounded-2xl bg-slate-900 px-10 text-base font-bold text-white transition-all hover:bg-emerald-600 hover:shadow-xl hover:shadow-emerald-500/20 active:scale-95 sm:w-auto"
      >
        Mulai Gratis
        <IoArrowForward
          className="h-5 w-5 transition-transform group-hover:translate-x-1"
        />
      </a>

      <a
        href="/login"
        class="inline-flex h-14 w-full items-center justify-center gap-2 rounded-2xl border border-slate-200 bg-white px-10 text-base font-bold text-slate-700 transition-all hover:border-emerald-500 hover:text-emerald-600 active:scale-95 sm:w-auto"
      >
        <IoLogInOutline size={22} />
        Masuk ke Akun
      </a>
    </div>

    <footer class="mt-8">
      <p class="text-sm font-medium text-slate-400">
        Butuh bantuan? <a
          href="/contact"
          class="text-emerald-600 hover:underline">Hubungi Tim Support kami</a
        >
      </p>
    </footer>
  </div>
</section>
